# Copy this file to ".env" and fill in your own values.
# The .env file is git-ignored and must NEVER be committed.

# Facebook Page ID. Put your own page ID here.
# You can find it in your Facebook Page settings:
# https://www.facebook.com/pages/?category=your_pages
FB_PAGE_ID=put_your_facebook_page_id_here

# Facebook Page access token. Put your own access token here.
# Generate it with Meta Graph API Explorer:
# https://developers.facebook.com/tools/explorer/
FB_ACCESS_TOKEN=put_your_facebook_page_access_token_here

# Optional overrides (defaults are fine for most users)
FB_GRAPH_API_VERSION=v17.0
GREETING_TEXT=Boldog névnapot
FONT_SIZE=70
